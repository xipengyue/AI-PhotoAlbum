# ============================================================
#   AI-PhotoAlbum 后端环境变量配置
# ============================================================

# ── 数据库 ──────────────────────────────────────────────
DATABASE_URL=postgresql://album:album@localhost:5433/photo_album

# ── JWT 认证 ───────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── 大模型 API（⚠️ 启动前必须配置）─────────────────────
# 支持 OpenAI / DeepSeek / SiliconFlow 等兼容接口
# 获取 Key: https://platform.openai.com 或 https://cloud.siliconflow.cn
OPENAI_API_KEY=sk-d032e41aa8d64f999d9e232e888118f7
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# ── 视觉模型 API（图像描述，需多模态模型）──────────────
# GLM-4V: 注册 https://open.bigmodel.cn 获取 API Key
# 也可用 gpt-4o / qwen-vl-max 等其他多模态模型
VISION_API_KEY=sk-cydtcmnwqdvoxovlyqezexexbislujihetwobqguikqexbyg
VISION_BASE_URL=https://api.siliconflow.cn/v1
VISION_MODEL=Qwen/Qwen3-VL-32B-Instruct

# ── MinIO 对象存储（可选）──────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=photo-album
MINIO_SECURE=false

# ── 应用配置 ───────────────────────────────────────────
APP_NAME=AI-PhotoAlbum
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO

# ── 文件存储 ───────────────────────────────────────────
UPLOAD_DIR=./data/uploads
THUMBNAIL_DIR=./data/thumbnails
MAX_UPLOAD_SIZE_MB=50

# ── AI 模型路径 ────────────────────────────────────────
MODELS_DIR=./data/models
